{
  "extends": "@repo/typescript-config/nextjs.json",
  "compilerOptions": {
    "plugins": [{ "name": "next" }],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@repo/i18n": ["../../packages/i18n/src/index.ts"],
      "@repo/i18n/*": ["../../packages/i18n/src/*"],
      "@repo/icons": ["../../packages/icons/src/index.ts"],
      "@repo/icons/*": ["../../packages/icons/src/*"]
    },
    "strictNullChecks": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "app/sign-in"
  ],
  "exclude": ["node_modules", "components/ai-elements"]
}
